# Copia para `.env` e preenche.

# PostgreSQL. Local: `docker compose up -d`. Produção: ligação do Render Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travel_costs?schema=public"

# Segredo de sessão (obrigatório). Gerar: `npx auth secret`
AUTH_SECRET="muda-me"

# Em produção (Render) deixar a true para confiar no host do proxy.
AUTH_TRUST_HOST="true"
